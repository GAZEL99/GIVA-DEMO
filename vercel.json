{
  "rewrites": [
    { "source": "/pages/bayar", "destination": "/pages/bayar.html" },
    { "source": "/pages/success", "destination": "/pages/success.html" },
    { "source": "/pages/product", "destination": "/pages/product.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ]
}
